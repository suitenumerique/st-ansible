---
name: messages
services:
  caddy:
    container_name: caddy
    image: docker.io/caddy:{{ st_messages_mpa_caddy_tag }}
    depends_on:
      - rspamd
    ports:
      - "{{ st_messages_mpa_caddy_port }}:80"
      - "{{ st_messages_mpa_caddy_healthcheck_port }}:90"
    volumes:
      - {{ st_messages_mpa_dir }}/caddy_config/Caddyfile:/etc/caddy/Caddyfile
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:90/healthcheck"]
      interval: 1m
      timeout: 3s
      start_period: 10s

  rspamd:
    container_name: rspamd
    image: docker.io/rspamd/rspamd:{{ st_messages_mpa_rspamd_tag }}
    depends_on:
      - clamav
      - unbound
      - valkey
    ports:
      - "{{ st_messages_mpa_rspamd_controller_port }}:11334"
    volumes:
      - {{ st_messages_mpa_dir }}/rspamd_data:/var/lib/rspamd
      - {{ st_messages_mpa_dir }}/rspamd_config:/etc/rspamd
    healthcheck:
      test: ["CMD-SHELL", "bash -c 'exec 3<>/dev/tcp/localhost/11334; printf \"GET /ping HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n\" >&3; grep \"pong\" <&3'"]
      interval: 1m
      timeout: 3s
      start_period: 10s

  clamav:
    container_name: clamav
    image: docker.io/clamav/clamav:{{ st_messages_mpa_clamav_tag }}
    volumes:
      - {{ st_messages_mpa_dir }}/clamav_config/clamd.conf:/etc/clamav/clamd.conf
    healthcheck:
      test: ["CMD", "clamdscan", "--ping", "1"]
      interval: 1m
      timeout: 3s
      start_period: 10s

  unbound:
    container_name: unbound
    image: docker.io/alpinelinux/unbound:latest
    entrypoint:
      - /bin/sh
      - -c
      - |
          unbound-anchor -a /etc/unbound/root.key
          exec unbound -dp
    volumes:
      - {{ st_messages_mpa_dir }}/unbound_config/unbound.conf:/etc/unbound/unbound.conf
    healthcheck:
      test: ["CMD", "unbound-control", "status"]
      interval: 10s
      timeout: 3s

  valkey:
    container_name: valkey
    image: docker.io/valkey/valkey:{{ st_messages_mpa_valkey_tag }}
    command: "valkey-server --save 60 1 --loglevel warning"
    volumes:
      - {{ st_messages_mpa_dir }}/valkey_data:/data
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 1m
      timeout: 3s
      start_period: 10s
