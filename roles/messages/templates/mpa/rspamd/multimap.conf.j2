{{ ansible_managed | comment }}
BLACKLIST_FROM_DOMAIN {
  type = "from";
  filter = "email:domain";
  map = "file:///var/lib/rspamd/blacklist_domains.map";
  score = 15.0;
}

BLACKLIST_TO_DOMAIN {
  type = "rcpt";
  filter = "email:domain";
  map = "file:///var/lib/rspamd/blacklist_domains.map";
  score = 15.0;
}

BLACKLIST_IP {
  type = "ip";
  prefilter = true;
  map = "file:///var/lib/rspamd/blacklist_ips.map";
  score = 15.0;
}

WHITELIST_FROM_DOMAIN {
  type = "from";
  filter = "email:domain";
  map = "file:///var/lib/rspamd/whitelist_domains.map";
  score = -15.0;
}

WHITELIST_IP {
  type = "ip";
  prefilter = true;
  map = "file:///var/lib/rspamd/whitelist_ips.map";
  action = "accept";
}

# Abuse.ch feeds — active malware URLs and known-bad attachment hashes
URLHAUS_ABUSE_CH {
  type = "selector";
  selector = "urls";
  map = "https://urlhaus.abuse.ch/downloads/text_online/";
  score = 10.0;
}

BAZAAR_ABUSE_CH {
  type = "selector";
  selector = "attachments(hex,md5)";
  map = "https://bazaar.abuse.ch/export/txt/md5/recent/";
  score = 10.0;
}
