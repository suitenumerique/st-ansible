---
{{ ansible_managed | comment }}

name: keycloak
services:
  keycloak:
    container_name: keycloak
    image: ghcr.io/suitenumerique/messages-keycloak:{{ st_keycloak_tag }}
    env_file: ./env
    environment:
      - KC_HTTP_PORT={{ st_keycloak_port }}
    network_mode: host
    command: {{ st_keycloak_start_command }}
